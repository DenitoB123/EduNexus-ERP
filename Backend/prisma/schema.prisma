generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ------------------------------------------------------------------
// Phase 1.1/1.2 — Infrastructure foundation only.
// No business/domain models are defined yet. This schema exists so
// PrismaClient can be generated and the connection lifecycle, health
// checks, and migration tooling can be validated end-to-end.
//
// Every future business model MUST include the following enterprise
// base fields (copy this block into new models):
//
//   id            String    @id @default(uuid())
//   tenantId      String    @map("tenant_id")
//   schoolGroupId String?   @map("school_group_id")
//   schoolId      String?   @map("school_id")
//   campusId      String?   @map("campus_id")
//   version       Int       @default(1)
//   createdAt     DateTime  @default(now()) @map("created_at")
//   updatedAt     DateTime  @updatedAt @map("updated_at")
//   deletedAt     DateTime? @map("deleted_at")
//   createdBy     String?   @map("created_by")
//   updatedBy     String?   @map("updated_by")
//   deletedBy     String?   @map("deleted_by")
//
//   @@index([tenantId])
//   @@index([deletedAt])
// ------------------------------------------------------------------

model HealthCheck {
  id        String   @id @default(uuid())
  status    String
  checkedAt DateTime @default(now())

  @@map("health_checks")
}

// Infrastructure-only seed tracking — records which seed scripts have
// run so seeding is idempotent. No business data.
model SeedLog {
  id         String   @id @default(uuid())
  name       String   @unique
  checksum   String
  executedAt DateTime @default(now()) @map("executed_at")
  durationMs Int      @map("duration_ms")

  @@map("seed_logs")
}

// ------------------------------------------------------------------
// B2.7 — Domain Events, Event Bus & Event-Driven Architecture.
// Event Store: durable, replayable, auditable record of every event
// that has passed through the EventBus/EventPublisher. Also functions
// as the transactional outbox table for TransactionalEventPublisher —
// rows are written inside the same DB transaction as the business
// change, then flushed to in-process/RabbitMQ delivery immediately
// after commit, with EventOutboxProcessor as a safety-net sweep for
// any row that never got flushed (process crash between commit and
// flush).
// ------------------------------------------------------------------

enum EventCategory {
  DOMAIN
  INTEGRATION
  APPLICATION
  NOTIFICATION
  AUDIT
  SYSTEM
}

enum EventPriority {
  LOW
  NORMAL
  HIGH
  CRITICAL
}

enum EventProcessingStatus {
  PENDING
  PUBLISHED
  FAILED
  DEAD_LETTERED
}

model DomainEventLog {
  id            String   @id @default(uuid())
  eventId       String   @unique @map("event_id")
  eventName     String   @map("event_name")
  eventVersion  Int      @default(1) @map("event_version")
  eventCategory EventCategory @map("event_category")
  priority      EventPriority @default(NORMAL)

  payload  Json
  metadata Json?

  tenantId      String? @map("tenant_id")
  schoolGroupId String? @map("school_group_id")
  schoolId      String? @map("school_id")
  campusId      String? @map("campus_id")

  correlationId String? @map("correlation_id")
  traceId       String? @map("trace_id")
  actorId       String? @map("actor_id")

  aggregateId   String? @map("aggregate_id")
  aggregateType String? @map("aggregate_type")

  occurredAt  DateTime @map("occurred_at")
  status      EventProcessingStatus @default(PENDING)
  publishedAt DateTime? @map("published_at")
  attempts    Int      @default(0)
  lastError   String?  @map("last_error")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([tenantId])
  @@index([eventName])
  @@index([status])
  @@index([correlationId])
  @@index([aggregateId])
  @@index([occurredAt])
  @@map("domain_event_log")
}

// Replay-protection / idempotency ledger: one row per (eventId, handler)
// that has successfully completed. Unique constraint is the mechanism —
// a second attempt to record the same pair fails, which EventReplayGuard
// treats as "already processed, skip".
model EventProcessingRecord {
  id          String   @id @default(uuid())
  eventId     String   @map("event_id")
  handlerName String   @map("handler_name")
  processedAt DateTime @default(now()) @map("processed_at")

  @@unique([eventId, handlerName])
  @@index([eventId])
  @@map("event_processing_record")
}
